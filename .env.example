# === Base de données PostgreSQL ===
POSTGRES_DB=livret_suivi
POSTGRES_USER=strapi
POSTGRES_PASSWORD=changez-moi-par-un-mot-de-passe-fort-2026

# === Strapi Configuration ===
NODE_ENV=development
HOST=0.0.0.0
PORT=1337

# Secrets Strapi (génère des valeurs fortes avec openssl rand -hex 32)
JWT_SECRET=ton-jwt-secret-super-long-et-aleatoire
ADMIN_JWT_SECRET=ton-admin-jwt-secret-super-long-et-aleatoire
APP_KEYS=cle1,c le2,cle3,cle4
API_TOKEN_SALT=ton-api-token-salt
TRANSFER_TOKEN_SALT=ton-transfer-token-salt

# === Frontend ===
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
# En production sur Render/Vercel, change en https://ton-strapi.onrender.com

# Envoi d'email (SendGrid)
SMTP_HOST=
